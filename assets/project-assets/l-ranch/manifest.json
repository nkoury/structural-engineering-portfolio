{
  "projectSlug": "l-ranch",
  "publicTitle": "L Ranch",
  "assetPolicy": {
    "clientNameVisible": false,
    "exactAddressVisible": false,
    "engineerStampVisible": false,
    "fullDrawingSetPublic": false,
    "originalU3DFilesPublic": false
  },
  "swiftxr": {
    "embedUrl": "",
    "projectUrl": "",
    "notes": "Paste the published SwiftXR iframe src URL into js/projects.js under the L Ranch swiftxr.embedUrl field."
  },
  "assets": {
    "hero": {
      "path": "preview/hero.webp",
      "type": "image",
      "caption": "Primary public-safe L Ranch visual"
    },
    "model": [
      {
        "path": "models/trellis-gltf-colors.glb",
        "type": "glb",
        "caption": "Preferred single-file model used by the native interactive viewer"
      },
      {
        "path": "models/Trellis gltf colors.gltf",
        "type": "gltf",
        "caption": "Alternate split GLTF source/reference export"
      },
      {
        "path": "models/Trellis gltf colors.bin",
        "type": "gltf-buffer",
        "caption": "External buffer required by the alternate split GLTF export"
      },
      {
        "path": "swiftxr-embed-url-in-js-projects",
        "type": "swiftxr-embed",
        "caption": "Interactive model viewer hosted by SwiftXR"
      },
      {
        "path": "models/source-u3d/",
        "type": "u3d-source-public-only",
        "caption": "Optional public-safe U3D source files; leave empty unless intentionally publishing"
      },
      {
        "path": "preview/model-still.webp",
        "type": "image",
        "caption": "Fallback model still for fast preview"
      }
    ],
    "drawings": [
      {
        "path": "drawings/plan-crop.webp",
        "type": "image",
        "caption": "Redacted plan excerpt"
      }
    ],
    "analysis": [
      {
        "path": "analysis/load-path.webp",
        "type": "image",
        "caption": "Load path or analysis visual"
      }
    ],
    "calculations": [
      {
        "path": "calculations/calc-excerpt.webp",
        "type": "image",
        "caption": "Selected public-safe calculation excerpt"
      }
    ]
  }
}
